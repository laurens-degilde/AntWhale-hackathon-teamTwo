{
  "name": "corridor-api",
  "version": "0.2.0",
  "description": "Wildlife corridor analysis backend. Stateless JSON API covering data assembly (OSM, GBIF, iNat, Waarneming verkeerslachtoffers, Sentinel-2, Copernicus, BRT/BGT, NNN, Atlas Natuurlijk Kapitaal, Kadaster, Rijkswaterstaat ecoducts), per-species resistance surfaces with peer-reviewed citations, connectivity analysis (current density + pinch points), intervention classification with cost & cost-effectiveness ranking, and output generation (GeoPackage manifest, technical report, landowner letters, subsidy applications, stakeholder map), plus stateless change detection.",
  "rateLimit": {"requestsPerMinute": 10, "scope": "per IP", "applies": "all /api/** except /api/health and /api/docs"},
  "errorEnvelope": {"error": "string", "status": "number", "timestamp": "ISO-8601"},
  "bboxFormats": {
    "default": "minLng,minLat,maxLng,maxLat",
    "overpass": "south,west,north,east"
  },
  "speciesEnum": ["badger", "otter", "red_deer", "pine_marten", "great_crested_newt", "hazel_dormouse"],
  "interventionEnum": ["ECODUCT", "WILDLIFE_UNDERPASS", "SMALL_MAMMAL_CULVERT", "AMPHIBIAN_TUNNEL", "HEDGEROW_PLANTING", "WILDFLOWER_STRIP", "FENCE_MODIFICATION", "FENCE_REMOVAL", "STEPPING_STONE_WOODLAND", "STEPPING_STONE_POND", "STEPPING_STONE_GRASSLAND"],
  "endpoints": [
    {"method": "GET", "path": "/api/health", "description": "Liveness probe.", "params": {}, "source": "internal"},
    {"method": "GET", "path": "/api/docs", "description": "This document.", "params": {}, "source": "internal"},

    {"method": "GET", "path": "/api/roadkills", "description": "Roadkill observations from iNaturalist (field:Roadkill=yes).",
     "params": {"taxonName": "string?", "placeId": "int?", "lat": "number?", "lng": "number?", "radius": "km?", "perPage": "int (≤200)", "page": "int"},
     "source": "inaturalist"},
    {"method": "GET", "path": "/api/inaturalist-occurrences", "description": "General iNaturalist observations (no roadkill filter).",
     "params": {"taxonName": "string?", "placeId": "int?", "lat": "number?", "lng": "number?", "radius": "km?", "perPage": "int (≤200)", "page": "int"},
     "source": "inaturalist"},
    {"method": "GET", "path": "/api/species-occurrences", "description": "Species observations from GBIF.",
     "params": {"taxonKey": "long (required)", "lat": "number?", "lng": "number?", "radiusKm": "number?", "dateAfter": "YYYY-MM-DD?", "dateBefore": "YYYY-MM-DD?", "limit": "int (≤300)", "offset": "int"},
     "source": "gbif"},
    {"method": "GET", "path": "/api/waarneming-roadkills", "description": "STUB. Waarneming.nl verkeerslachtoffers feed; needs partner token in production.",
     "params": {"limit": "int (≤500)"}, "source": "waarneming-verkeerslachtoffers", "stub": true},

    {"method": "GET", "path": "/api/land-cover", "description": "STUB. Copernicus CORINE-style land-cover summary.",
     "params": {"bbox": "string (required)", "resolution": "100m | 10m"}, "source": "copernicus", "stub": true},
    {"method": "GET", "path": "/api/sentinel2-imagery", "description": "STUB. Sentinel-2 L2A item references via Element 84 STAC.",
     "params": {"bbox": "string (required)", "dateAfter": "YYYY-MM-DD?", "dateBefore": "YYYY-MM-DD?", "maxCloudCoverPct": "int 0-100"}, "source": "sentinel-2-l2a", "stub": true},
    {"method": "GET", "path": "/api/osm-features", "description": "OSM via Overpass. NB Overpass bbox order: south,west,north,east.",
     "params": {"bbox": "south,west,north,east", "featureTypes": "csv of [roads, waterways, buildings, landuse, fences]"},
     "source": "openstreetmap"},
    {"method": "GET", "path": "/api/brt-bgt", "description": "STUB. PDOK BRT TOP10NL or BGT topography.",
     "params": {"bbox": "string (required)", "dataset": "BRT | BGT"}, "source": "pdok", "stub": true},
    {"method": "GET", "path": "/api/nnn", "description": "STUB. Provincial Natuur Netwerk Nederland layers.",
     "params": {"province": "string (default Gelderland)", "bbox": "string (required)"}, "source": "provinces (PDOK)", "stub": true},
    {"method": "GET", "path": "/api/atlas-natuurlijk-kapitaal", "description": "STUB. Ecosystem-services indicators for the bbox.",
     "params": {"bbox": "string (required)"}, "source": "atlas-natuurlijk-kapitaal", "stub": true},
    {"method": "GET", "path": "/api/cadastre/parcels", "description": "STUB. Kadaster parcels; ownership requires BRK 2.0 auth.",
     "params": {"bbox": "string (required)", "limit": "int (≤500)"}, "source": "kadaster", "stub": true},
    {"method": "GET", "path": "/api/ecoducts", "description": "STUB. Curated Dutch ecoduct/underpass/amphibian-tunnel inventory.",
     "params": {}, "source": "rijkswaterstaat", "stub": true},

    {"method": "GET", "path": "/api/resistance-surface", "description": "Per-species resistance coefficients. Each coefficient ships with its peer-reviewed citation.",
     "params": {"species": "speciesEnum", "bbox": "string (required)", "resolution": "100m | 250m"},
     "source": "internal (peer-reviewed)", "stub": true},
    {"method": "GET", "path": "/api/habitat-patches", "description": "STUB. Source / destination / stepping-stone habitat patches per species.",
     "params": {"species": "speciesEnum", "bbox": "string (required)"}, "source": "internal", "stub": true},
    {"method": "GET", "path": "/api/connectivity", "description": "STUB. Circuitscape/Omniscape current-density grid.",
     "params": {"species": "speciesEnum", "bbox": "string (required)", "engine": "CIRCUITSCAPE | OMNISCAPE"},
     "source": "internal", "stub": true},
    {"method": "GET", "path": "/api/pinch-points", "description": "STUB. Top-N bottleneck locations.",
     "params": {"species": "speciesEnum", "bbox": "string (required)", "topN": "int 1-50"}, "source": "internal", "stub": true},
    {"method": "GET", "path": "/api/interventions", "description": "STUB. Classified interventions with cost range, benefit, and cost-effectiveness rank.",
     "params": {"species": "speciesEnum", "bbox": "string (required)", "topN": "int 1-50"}, "source": "internal", "stub": true},

    {"method": "GET", "path": "/api/outputs/geopackage-manifest", "description": "STUB. Layer manifest a GeoPackage/Shapefile renderer would consume.",
     "params": {"species": "speciesEnum", "bbox": "string (required)"}, "source": "internal", "stub": true},
    {"method": "GET", "path": "/api/outputs/technical-report", "description": "STUB. Technical-report payload (methods, assumptions, coefficients with citations, ranked interventions).",
     "params": {"species": "speciesEnum", "bbox": "string (required)"}, "source": "internal", "stub": true},
    {"method": "GET", "path": "/api/outputs/landowner-letters", "description": "STUB. One letter per affected parcel, personalised with intervention + subsidy options.",
     "params": {"species": "speciesEnum", "bbox": "string (required)"}, "source": "internal", "stub": true},
    {"method": "GET", "path": "/api/outputs/subsidy-applications", "description": "STUB. Pre-filled ANLb / GLB application payloads.",
     "params": {"species": "speciesEnum", "bbox": "string (required)"}, "source": "internal", "stub": true},
    {"method": "GET", "path": "/api/outputs/stakeholder-map", "description": "STUB. Municipalities / water boards / NGOs / road authority required for sign-off.",
     "params": {"species": "speciesEnum", "bbox": "string (required)"}, "source": "internal", "stub": true},

    {"method": "POST", "path": "/api/change-detection", "description": "STUB. Stateless diff between two RegionSnapshot bodies. Returns new roadkill clusters, land-use shifts, building deltas, ranking shifts, and plan-amendment bullets.",
     "body": "{previous: RegionSnapshot, current: RegionSnapshot}", "source": "internal", "stub": true}
  ]
}
