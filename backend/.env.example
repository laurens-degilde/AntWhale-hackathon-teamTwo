# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored, so each developer keeps their own keys.
# Loaded automatically by `spring-dotenv` at startup — no source-ing needed.
#
# All current external APIs (iNaturalist, GBIF, Overpass) are open and need no auth,
# so this file is empty by default. Add keys here as you wire up new sources.

# Example: override the rate limit for local testing
# RATELIMIT_REQUESTS_PER_MINUTE=100

# Example: change the server port
# SERVER_PORT=8081
